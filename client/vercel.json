{
  "buildCommand": "npm run build:skip-ts",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://ethio-ai-server.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
