{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "src/types/*"]
    }
  },
  "include": ["src/types/**/*"],
  "exclude": ["node_modules", "src/services/**/*", "src/modules/**/*", "src/controllers/**/*", "src/routes/**/*", "src/middlewares/**/*", "src/test-notification-infrastructure.ts", "src/controllers/tour.controller.ts", "src/controllers/webhook.controller.ts", "src/middlewares/cache.middleware.ts", "src/middlewares/logging.middleware.ts", "src/middlewares/performance.middleware.ts", "src/middlewares/security.middleware.ts", "src/routes/ai.routes.ts", "src/routes/reviews.routes.ts", "src/server.ts"]
}