{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "noEmitOnError": false,
    "paths": {
      "*": ["node_modules/*", "src/types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "src/modules/booking/booking.controller.ts",
    "src/modules/booking/booking.service.ts",
    "src/modules/booking/dto/create-booking.dto.ts",
    "src/modules/booking/entities/booking.entity.ts",
    "src/services/notification/base.service.ts",
    "src/services/notification/enhanced-notification.service.ts",
    "src/services/notification/enhanced-queue.service.ts",
    "src/services/notification/notification.service.ts",
    "src/services/notification/preferences.service.ts",
    "src/services/notification/processor.service.ts",
    "src/services/notification/queue.service.ts",
    "src/services/notification/index.ts",
    "src/services/order.service.ts",
    "src/services/product.service.ts",
    "src/services/vendor.service.ts",
    "src/services/cultural.service.ts",
    "src/services/modern-ai.service.ts",
    "src/controllers/order.controller.ts",
    "src/controllers/product.controller.ts",
    "src/controllers/vendor.controller.ts",
    "src/controllers/cultural.controller.ts",
    "src/test-notification-infrastructure.ts"
  ]
}
